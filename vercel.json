{
  "version": 2,
  "functions": {
    "api/chat.js":   { "memory": 256, "maxDuration": 30 },
    "api/vision.js": { "memory": 256, "maxDuration": 30 }
  },
  "routes": [
    { "src": "/api/chat",   "dest": "/api/chat.js" },
    { "src": "/api/vision", "dest": "/api/vision.js" },
    { "src": "/(.*)",       "dest": "/index.html" }
  ]
}
