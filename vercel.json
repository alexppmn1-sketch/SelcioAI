{
  "version": 2,
  "functions": {
    "api/chat.js":   { "memory": 256, "maxDuration": 30 },
    "api/vision.js": { "memory": 256, "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/api/chat", "destination": "/api/chat.js" },
    { "source": "/api/vision", "destination": "/api/vision.js" }
  ],
  "headers": [
    {
      "source": "/(.*\\.(ico|png|jpg|jpeg|webp|svg|json))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
